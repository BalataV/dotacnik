        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "supabaseUrl": "https://fbhwsrclexkhpbfiwprw.supabase.co",
      "supabaseAnonKey": "sb_publishable_HeHvUgksqdXQV2kfqTBVHg_UGkY1ib4",
      "eas": {
        "projectId": "b1122417-e0d5-47ea-ad71-dcf4b5e90cc1"
      }
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dotačník potřebuje přístup k fotkám, abys mohl přidat účtenku k výdaji.",
          "cameraPermission": "Dotačník potřebuje přístup k fotoaparátu, abys mohl vyfotit účtenku.",
